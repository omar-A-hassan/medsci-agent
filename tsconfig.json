{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@medsci/core": ["packages/core/src"],
      "@medsci/core/*": ["packages/core/src/*"]
    },
    "types": ["bun-types"]
  },
  "exclude": ["node_modules", "dist"]
}
