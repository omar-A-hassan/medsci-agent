{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"ollama": {
			"models": {
				"medgemma:latest": {}
			}
		}
	},
	"model": "ollama/medgemma:latest",
	"permission": {
		"edit": "ask",
		"task": "ask",
		"skill": "ask",
		"webfetch": "ask",
		"external_directory": "ask",
		"doom_loop": "ask",
		"bash": {
			"*": "ask",
			"pwd": "allow",
			"ls*": "allow",
			"git status*": "allow",
			"git diff*": "allow",
			"git log*": "allow",
			"grep *": "allow",
			"find *": "allow",
			"bun test*": "allow",
			"bun run typecheck*": "allow",
			"bun run lint*": "allow",
			"rm *": "deny",
			"git push*": "deny"
		}
	},
	"agent": {
		"medsci": {
			"permission": {
				"task": {
					"*": "ask",
					"explore": "allow",
					"general": "allow"
				},
				"skill": {
					"*": "ask",
					"operational-guardrails": "allow",
					"sandbox-execution": "allow",
					"scanpy": "allow",
					"pubmed": "allow",
					"chembl": "allow",
					"uniprot": "allow"
				}
			}
		}
	},
	"mcp": {
		"ace-mcp": {
			"type": "local",
			"command": [
				"bash",
				"-lc",
				"if [ -x packages/server-paperqa/.venv-paperqa/bin/ace-mcp ]; then exec packages/server-paperqa/.venv-paperqa/bin/ace-mcp; elif command -v ace-mcp >/dev/null 2>&1; then exec ace-mcp; else echo 'ace-mcp not found. Run: bun run setup:py:paperqa (or uv sync group paperqa+ace into packages/server-paperqa/.venv-paperqa)' >&2; exit 1; fi"
			],
			"timeout": 300000,
			"environment": {
				"ACE_MCP_DEFAULT_MODEL": "openrouter/arcee-ai/trinity-large-preview:free",
				"ACE_MCP_SAFE_MODE": "false",
				"ACE_MCP_ALLOW_SAVE_LOAD": "true",
				"ACE_MCP_SESSION_TTL_SECONDS": "86400",
				"ACE_MCP_LEARN_TIMEOUT_SECONDS": "300",
				"ACE_MCP_MAX_SAMPLES_PER_CALL": "10",
				"ACE_MCP_SKILLBOOK_ROOT": ".opencode/ace/skillbooks"
			}
		},
		"medsci-omics": {
			"type": "local",
			"command": ["bun", "run", "packages/server-omics/src/index.ts"],
			"timeout": 300000,
			"environment": {
				"MEDSCI_PROFILE": "standard",
				"MEDSCI_PYTHON": ".venv/bin/python3",
				"MEDSCI_OLLAMA_TIMEOUT": "120000"
			}
		},
		"medsci-drug": {
			"type": "local",
			"command": ["bun", "run", "packages/server-drug/src/index.ts"],
			"timeout": 300000,
			"environment": {
				"MEDSCI_PROFILE": "standard",
				"MEDSCI_PYTHON": ".venv/bin/python3",
				"MEDSCI_OLLAMA_TIMEOUT": "120000"
			}
		},
		"medsci-protein": {
			"type": "local",
			"command": ["bun", "run", "packages/server-protein/src/index.ts"],
			"timeout": 300000,
			"environment": {
				"MEDSCI_PROFILE": "standard",
				"MEDSCI_PYTHON": ".venv/bin/python3",
				"MEDSCI_OLLAMA_TIMEOUT": "120000"
			}
		},
		"medsci-imaging": {
			"type": "local",
			"command": ["bun", "run", "packages/server-imaging/src/index.ts"],
			"timeout": 300000,
			"environment": {
				"MEDSCI_PROFILE": "standard",
				"MEDSCI_PYTHON": ".venv/bin/python3",
				"MEDSCI_OLLAMA_TIMEOUT": "120000"
			}
		},
		"medsci-literature": {
			"type": "local",
			"command": ["bun", "run", "packages/server-literature/src/index.ts"],
			"timeout": 300000,
			"environment": {
				"MEDSCI_PROFILE": "standard",
				"MEDSCI_PYTHON": ".venv/bin/python3",
				"MEDSCI_OLLAMA_TIMEOUT": "120000"
			}
		},
		"medsci-acquisition": {
			"type": "local",
			"command": ["bun", "run", "packages/server-acquisition/src/index.ts"],
			"timeout": 300000,
			"environment": {
				"MEDSCI_PROFILE": "standard",
				"MEDSCI_PYTHON": "packages/server-paperqa/.venv-paperqa/bin/python3",
				"MEDSCI_OLLAMA_TIMEOUT": "120000"
			}
		},
		"medsci-paperqa": {
			"type": "local",
			"command": ["bun", "run", "packages/server-paperqa/src/index.ts"],
			"timeout": 600000,
			"environment": {
				"MEDSCI_PYTHON": "packages/server-paperqa/.venv-paperqa/bin/python3",
				"PQA_LLM_MODEL": "ollama/medgemma:latest",
				"PQA_EMBEDDING_MODEL": "ollama/mxbai-embed-large",
				"PQA_OLLAMA_URL": "http://localhost:11434",
				"PQA_LLM_TIMEOUT_SECONDS": "480",
				"PQA_EVIDENCE_K": "5"
			}
		},
		"medsci-sandbox": {
			"type": "local",
			"command": ["bun", "run", "packages/server-sandbox/src/index.ts"],
			"timeout": 600000,
			"environment": {
				"MEDSCI_PROFILE": "standard"
			}
		}
	}
}
