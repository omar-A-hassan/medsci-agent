{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "models": {
        "medgemma:latest": {}
      }
    }
  },
  "model": "ollama/ministral-3:8b-instruct-2512-q4_K_M",
  "mcp": {
    "medsci-omics": {
      "type": "local",
      "command": ["bun", "run", "packages/server-omics/src/index.ts"],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    },
    "medsci-drug": {
      "type": "local",
      "command": ["bun", "run", "packages/server-drug/src/index.ts"],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    },
    "medsci-protein": {
      "type": "local",
      "command": ["bun", "run", "packages/server-protein/src/index.ts"],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    },
    "medsci-imaging": {
      "type": "local",
      "command": ["bun", "run", "packages/server-imaging/src/index.ts"],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    },
    "medsci-literature": {
      "type": "local",
      "command": ["bun", "run", "packages/server-literature/src/index.ts"],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    }
  }
}