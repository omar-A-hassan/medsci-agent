{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "models": {
        "medgemma:latest": {}
      }
    }
  },
  "model": "ollama/medgemma:latest",
  "mcp": {
    "medsci-omics": {
      "type": "local",
      "command": [
        "bun",
        "run",
        "packages/server-omics/src/index.ts"
      ],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    },
    "medsci-drug": {
      "type": "local",
      "command": [
        "bun",
        "run",
        "packages/server-drug/src/index.ts"
      ],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    },
    "medsci-protein": {
      "type": "local",
      "command": [
        "bun",
        "run",
        "packages/server-protein/src/index.ts"
      ],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    },
    "medsci-imaging": {
      "type": "local",
      "command": [
        "bun",
        "run",
        "packages/server-imaging/src/index.ts"
      ],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    },
    "medsci-literature": {
      "type": "local",
      "command": [
        "bun",
        "run",
        "packages/server-literature/src/index.ts"
      ],
      "timeout": 300000,
      "environment": {
        "MEDSCI_PROFILE": "standard",
        "MEDSCI_PYTHON": ".venv/bin/python3"
      }
    },
    "medsci-paperqa": {
      "type": "local",
      "command": [
        "bun",
        "run",
        "packages/server-paperqa/src/index.ts"
      ],
      "timeout": 600000,
      "environment": {
        "MEDSCI_PYTHON": ".venv-paperqa/bin/python3"
      }
    }
  }
}