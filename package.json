{
	"name": "medsci-agent",
	"private": true,
	"version": "0.1.0",
	"description": "MedSci Agent — Multi-agent scientific CLI for OpenCode powered by MedGemma and HAI-DEF models",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"setup:py:core": "uv venv .venv && VIRTUAL_ENV=.venv uv sync --active --no-default-groups --group scientific --group test",
		"setup:py:paperqa": "uv venv packages/server-paperqa/.venv-paperqa && VIRTUAL_ENV=packages/server-paperqa/.venv-paperqa uv sync --active --no-default-groups --group paperqa --group ace --group test",
		"setup:py:all": "bun run setup:py:core && bun run setup:py:paperqa",
		"test": "bun test --recursive",
		"test:coverage": "bun test --recursive --coverage",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"server:omics": "bun run packages/server-omics/src/index.ts",
		"server:drug": "bun run packages/server-drug/src/index.ts",
		"server:protein": "bun run packages/server-protein/src/index.ts",
		"server:imaging": "bun run packages/server-imaging/src/index.ts",
		"server:literature": "bun run packages/server-literature/src/index.ts",
		"server:acquisition": "bun run packages/server-acquisition/src/index.ts",
		"server:paperqa": "bun run packages/server-paperqa/src/index.ts",
		"server:sandbox": "bun run packages/server-sandbox/src/index.ts",
		"test:python": "packages/server-paperqa/.venv-paperqa/bin/python -m pytest packages/server-paperqa/src/__tests__/test_paperqa_server.py",
		"test:all": "bun test --recursive && packages/server-paperqa/.venv-paperqa/bin/python -m pytest packages/server-paperqa/src/__tests__/test_paperqa_server.py"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"bun-types": "^1.3.9",
		"typescript": "^5.7.0"
	},
	"engines": {
		"bun": ">=1.1.0"
	},
	"license": "MIT"
}
