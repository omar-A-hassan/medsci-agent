{
	"name": "medsci-agent",
	"private": true,
	"version": "0.1.0",
	"description": "MedSci Agent — Multi-agent scientific CLI for OpenCode powered by MedGemma and HAI-DEF models",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"test": "bun test --recursive",
		"test:coverage": "bun test --recursive --coverage",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"server:omics": "bun run packages/server-omics/src/index.ts",
		"server:drug": "bun run packages/server-drug/src/index.ts",
		"server:protein": "bun run packages/server-protein/src/index.ts",
		"server:imaging": "bun run packages/server-imaging/src/index.ts",
		"server:literature": "bun run packages/server-literature/src/index.ts",
		"server:paperqa": "bun run packages/server-paperqa/src/index.ts",
		"server:sandbox": "bun run packages/server-sandbox/src/index.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"bun-types": "^1.3.9",
		"typescript": "^5.7.0"
	},
	"engines": {
		"bun": ">=1.1.0"
	},
	"license": "MIT"
}